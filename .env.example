NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# פרודקשן: הוסף ב-Vercel → Settings → Environment Variables (אותו ערך). גיבוי להפניות OAuth.
NEXT_PUBLIC_SITE_URL=https://miluim-dashboard.vercel.app

# Server-only: יצירת משתמשים / איפוס סיסמה / מחיקה (לעולם לא בקליינט)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# אופציונלי: אותו ערך כמו למעלה אם בפרויקט משתמשים בשם הזה
# SUPABASE_SERVICE_KEY=
